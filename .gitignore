# ─────────────────────────────────────────────────────────────
# SovereignWatch .gitignore
# ─────────────────────────────────────────────────────────────

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# MaxMind GeoIP databases (licensed, download separately)
data/*.mmdb
data/*.tar.gz

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# Build outputs
dist/
build/
out/
.next/
.cache/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Docker volumes mirrored locally
pgdata/
changedata/
kumadata/

# Logs
logs/
*.log

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Test outputs
coverage/
.nyc_output/

# Local development
.local/
tmp/
sovpro

# Playwright MCP artifacts
.playwright-mcp/
*.playwright.png

# Claude Code local agent state
.claude/
